{
  "version": 2,
  "loops": [
    {
      "taskId": "fetch-issues",
      "intervalHuman": "0",
      "description": "Fetch issue count; on failure log silently, on success report"
    }
  ],
  "tasks": [
    {
      "id": "fetch-issues",
      "name": "Fetch issues",
      "command": "gh",
      "commandArgs": [
        "issue",
        "list",
        "--state",
        "all",
        "--json",
        "number",
        "--limit",
        "500",
        "--jq",
        "{total: length}"
      ],
      "onSuccessTaskId": "report",
      "onFailureTaskId": "log-silent-error"
    },
    {
      "id": "report",
      "name": "Report count",
      "command": "echo",
      "commandArgs": [
        "total issues (open + closed): {{total}}"
      ],
      "onSuccessTaskId": null,
      "onFailureTaskId": null
    },
    {
      "id": "log-silent-error",
      "name": "Log error (silent)",
      "command": "echo",
      "commandArgs": [
        "gh failed or not authenticated, nothing to report"
      ],
      "silentChain": true,
      "onSuccessTaskId": null,
      "onFailureTaskId": null
    }
  ]
}