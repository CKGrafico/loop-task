{
  "name": "loop-task",
  "version": "1.1.0",
  "description": "A cross-platform CLI that repeatedly executes a shell command at a human-readable interval",
  "type": "module",
  "bin": {
    "loop-task": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "pnpm run build && vitest run",
    "test:watch": "pnpm run build && vitest",
    "test:coverage": "pnpm run build && vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "release:dry": "pnpm run build && pnpm publish --dry-run",
    "release": "pnpm run build && pnpm publish"
  },
  "keywords": [
    "cli",
    "loop",
    "repeat",
    "interval",
    "schedule",
    "timer",
    "cron",
    "automation",
    "devops",
    "agent"
  ],
  "author": "Quique Fdez Guerra",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "commander": "^13.1.0",
    "execa": "^9.6.0",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.25.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0",
    "vitest": "^3.1.0"
  }
}
